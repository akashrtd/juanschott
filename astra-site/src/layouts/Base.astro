---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = "JuanSchott — Open-source competitive multiplayer FPS built on Bevy. Join us." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner container">
        <a href="/" class="nav-logo">
          <span class="logo-mark">J</span>
          <span>JuanSchott</span>
        </a>
        <div class="nav-links">
          <a href="#about">About</a>
          <a href="#tech">Tech</a>
          <a href="#roadmap">Roadmap</a>
          <a href="#contribute">Contribute</a>
          <a href="#docs">Docs</a>
        </div>
        <div class="nav-actions">
          <a href="https://github.com/akashrtd/juanschott" target="_blank" class="btn btn-primary btn-sm">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="logo-mark">J</span>
          <span>JuanSchott</span>
          <p class="footer-tagline">One Shot. God's Blessing. The Ship.</p>
        </div>
        <div class="footer-links">
          <div>
            <h4>Project</h4>
            <a href="https://github.com/akashrtd/juanschott">Source Code</a>
            <a href="https://github.com/akashrtd/juanschott/issues">Issues</a>
            <a href="https://github.com/akashrtd/juanschott/pulls">Pull Requests</a>
          </div>
          <div>
            <h4>Resources</h4>
            <a href="https://github.com/akashrtd/juanschott/tree/main/resources">Design Docs</a>
            <a href="https://github.com/akashrtd/juanschott/blob/main/resources/00_foundation/vision_and_origin.md">Vision</a>
            <a href="https://github.com/akashrtd/juanschott/blob/main/resources/04_technical/architecture_overview.md">Architecture</a>
          </div>
          <div>
            <h4>Community</h4>
            <a href="#">Discord</a>
            <a href="https://github.com/akashrtd/juanschott/discussions">Discussions</a>
          </div>
        </div>
        <div class="footer-bottom">
          <p>MIT OR Apache-2.0 License</p>
          <p>Built with Bevy. Made with Rust.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 1.5rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .nav-logo:hover {
    color: var(--text-primary);
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--accent-gold);
    color: var(--bg-primary);
    font-weight: 800;
    font-size: 1rem;
    border-radius: 6px;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .btn-sm {
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
  }

  .footer {
    border-top: 1px solid var(--border);
    padding: 4rem 1.5rem 2rem;
    background: var(--bg-secondary);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.1rem;
    flex-wrap: wrap;
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-left: 0.5rem;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 2rem;
  }

  .footer-links h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .footer-links a {
    display: block;
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding: 0.25rem 0;
  }

  .footer-links a:hover {
    color: var(--accent-teal);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
  }
</style>
